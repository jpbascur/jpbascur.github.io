      h1 { font-size: 32px; font-weight: 500; margin-bottom: 2rem; }
      .cv-note { font-size: 14px; color: #555; margin-bottom: 1rem; }
      details { border: 1px solid #eee; border-radius: 12px; overflow: hidden; margin-bottom: 2rem; }
      summary { font-size: 15px; font-weight: 500; padding: 1rem 1.25rem; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
      summary::-webkit-details-marker { display: none; }
      summary::after { content: '+'; font-size: 20px; color: #aaa; }
      details[open] summary::after { content: '−'; }
      summary:hover { background: #fafafa; }
      .btn { font-size: 13px; padding: 8px 18px; border-radius: 999px; border: 1px solid #ddd; color: #534AB7; text-decoration: none; }
      .btn:hover { background: #f5f5f5; }
      .section-title { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #aaa; margin-bottom: 1rem; }
      .prose { font-size: 15px; color: #555; line-height: 1.7; }
