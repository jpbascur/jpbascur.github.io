---
// Work history page: warm, narrative, for curious readers. Tells the story behind the resume. Content lives in src/content/work/history.md
import { getEntry, render } from 'astro:content';

const entry = await getEntry('work', 'history');
const { Content } = await render(entry!);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Detailed Work History — Juan Pablo Bascur</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; color: #1a1a1a; }
      .page { max-width: 1100px; margin: 0 auto; padding: 3rem 8rem; }
      nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem; }
      h1 { font-size: 32px; font-weight: 500; margin-bottom: 0.5rem; }
      .subtitle { font-size: 14px; color: #888; margin-bottom: 2.5rem; }
      .layout { display: flex; gap: 3rem; align-items: flex-start; }
      .toc { width: 180px; flex-shrink: 0; position: sticky; top: 2rem; }
      .toc-title { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #aaa; margin-bottom: 1rem; }
      .toc a { display: block; font-size: 13px; color: #888; text-decoration: none; padding: 4px 0; border-left: 2px solid #eee; padding-left: 10px; transition: color 0.15s, border-color 0.15s; }
      .toc a:hover { color: #1a1a1a; border-left-color: #534AB7; }
      .prose { flex: 1; min-width: 0; }
      .prose { font-size: 15px; color: #555; line-height: 1.7; }
      .prose h2 { font-size: 20px; font-weight: 500; color: #1a1a1a; margin: 2.5rem 0 1rem; }
      .prose h3 { font-size: 16px; font-weight: 500; color: #1a1a1a; margin: 1.5rem 0 0.5rem; }
      .prose p { margin-bottom: 1rem; }
      .prose ul { margin: 0.5rem 0 1rem 1.5rem; }
      .prose li { margin-bottom: 0.25rem; }
      .prose hr { border: none; border-top: 1px solid #eee; margin: 2rem 0; }
      .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; font-size: 13px; }
      .prose th { text-align: left; border-bottom: 1px solid #ddd; padding: 6px 8px; color: #1a1a1a; }
      .prose td { border-bottom: 1px solid #f0f0f0; padding: 6px 8px; }
      .prose a { color: #534AB7; text-decoration: none; }
      .prose a:hover { text-decoration: underline; }
      .prose em { color: #aaa; }
    </style>
  </head>
  <body>
  <div class="page">
    <nav>
      <a href="/professional" style="font-size: 13px; color: #888; text-decoration: none;">← Professional Space</a>
    </nav>

    <h1>Detailed Work History</h1>

    <div class="layout">
      <div class="toc">
        <div class="toc-title">Contents</div>
        <a href="#personal-information">Personal Information</a>
        <a href="#topics-of-expertise">Topics of Expertise</a>
        <a href="#programming-languages">Programming Languages</a>
        <a href="#natural-languages">Natural Languages</a>
        <a href="#education">Education</a>
        <a href="#work-experience">Work Experience</a>
        <a href="#teaching">Teaching</a>
        <a href="#academic-service">Academic Service</a>
        <a href="#peer-reviews">Peer Reviews</a>
        <a href="#conferences">Conferences</a>
      </div>

      <div class="prose">
        <Content />
      </div>
    </div>
  </div>
  </body>
</html>
