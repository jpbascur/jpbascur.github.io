---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Juan Pablo Bascur</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; }
      body {
        font-family: system-ui, sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: #f9f9f9;
        color: #1a1a1a;
      }
      .name {
        font-size: 18px;
        font-weight: 500;
        letter-spacing: 0.02em;
        margin-bottom: 3rem;
        color: #888;
      }
      .choices {
        display: flex;
        gap: 1.5rem;
      }
      .choice {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 200px;
        height: 200px;
        border-radius: 16px;
        text-decoration: none;
        font-size: 16px;
        font-weight: 500;
        letter-spacing: 0.01em;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }
      .choice:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.12);
      }
      .choice-icon {
        font-size: 36px;
        margin-bottom: 0.75rem;
      }
      .choice-desc {
        font-size: 11px;
        font-weight: 400;
        opacity: 0.7;
        margin-top: 4px;
        text-align: center;
        max-width: 140px;
        line-height: 1.5;
      }
      .professional {
        background: #534AB7;
        color: white;
      }
      .personal {
        background: #1a1a1a;
        color: #f5f0e8;
      }
      @media (max-width: 480px) {
        .choices { flex-direction: column; }
        .choice { width: 180px; height: 180px; }
      }
    </style>
  </head>
  <body>
    <div class="name">Juan Pablo Bascur</div>
    <div class="choices">
      <a class="choice professional" href="/professional">
        <div class="choice-icon">💼</div>
        Professional space
        <div class="choice-desc">CV, experience & projects</div>
      </a>
      <a class="choice personal" href="/personal">
        <div class="choice-icon">✦</div>
        Personal space
        <div class="choice-desc">Writing, hobbies & everything else</div>
      </a>
    </div>
  </body>
</html>
