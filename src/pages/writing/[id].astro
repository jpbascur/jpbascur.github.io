---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(story => ({ params: { id: story.id }, props: { story } }));
}

const { story } = Astro.props;
const { Content } = await render(story);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{story.data.title} — Juan Pablo Bascur</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Georgia', serif; background: #1a1a1a; color: #f5f0e8; min-height: 100vh; padding: 2.5rem 1.5rem; }
      nav { display: flex; justify-content: space-between; align-items: center; max-width: 680px; margin: 0 auto 4rem; }
      nav a { font-size: 13px; color: #555; text-decoration: none; font-family: system-ui, sans-serif; }
      nav a:hover { color: #f5f0e8; }
      .content { max-width: 680px; margin: 0 auto; }
      .note { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #444; font-family: system-ui, sans-serif; margin-bottom: 1.25rem; }
      h1 { font-size: 40px; font-weight: 400; line-height: 1.2; margin-bottom: 2.5rem; }
      .prose { font-size: 18px; color: #c8c0b0; line-height: 1.85; }
      .prose p { margin-bottom: 1.5rem; }
      .prose em { color: #f5f0e8; font-style: italic; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/writing">← Stories</a>
    </nav>
    <div class="content">
      {story.data.note && <div class="note">{story.data.note}</div>}
      <h1>{story.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </div>
  </body>
</html>
